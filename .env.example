# ── Application ────────────────────────────────────────────────────────────────
APP_TITLE=OCPP Admin

# ── Network ────────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8080

# ── Database (PostgreSQL) ──────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=ocppcore
DB_USER=ocpp
DB_PASS=changeme

# ── OCPP Core API ──────────────────────────────────────────────────────────────
# URL of the OCPP Core REST API (e.g. your ocpp-core service)
OCPP_CORE_API=http://localhost:8000

# ── PKI ────────────────────────────────────────────────────────────────────────
# Directory containing root-ca.crt and users/ sub-directory
# Default: ../ocpp-core/data/pki (relative to this project)
PKI_DATA_DIR=../ocpp-core/data/pki
